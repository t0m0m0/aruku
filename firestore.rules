rules_version = '2';

// このプロジェクトの Firestore はサーバ専用（Cloud Functions の Admin SDK のみが
// 利用する）。レートリミッタの rateLimits コレクションを含め、クライアント SDK から
// の読み書きは全面拒否する。Admin SDK はセキュリティルールをバイパスするため、
// レートリミッタの動作には影響しない。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
